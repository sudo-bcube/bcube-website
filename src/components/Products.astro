---
const features = [
  {
    title: "Instant Recognition",
    text: "Hear any verse and instantly see the Arabic text, transliteration, and translation. No matter the recitation style.",
  },
  {
    title: "Real time flow",
    text: "Recognize and identify Quran recitations in real time. No need to pause or rewind.",
  },
  {
    title: "Intuitive search",
    text: "Find any verse or surah quickly with an intuitive search.",
  },
  {
    title: "Read and share",
    text: "Read the entire Quran seamlessly, or share meaningful verses with loved ones.",
  },
  {
    title: "Stay present",
    text: "Every interaction keeps you in sync with your recitation, so you can focus, reflect, and feel the moment fully.",
  },
];
---

<section id="products" class="bg-dark-blue px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <h2 class="text-center text-3xl font-bold text-white sm:text-4xl">
      A small collection of mighty apps
    </h2>

    <div class="mt-16 rounded-3xl bg-white/10 p-8 backdrop-blur-sm sm:p-12">
      <div class="flex items-center gap-3">
        <span class="text-2xl font-bold text-white">Lawh</span>
        <span class="text-pastel-azure">— Instant Quran Recognition</span>
      </div>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((feature) => (
          <div class="rounded-xl bg-white/5 p-6">
            <h3 class="font-semibold text-pastel-azure">{feature.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-white/70">{feature.text}</p>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a
          href={import.meta.env.PUBLIC_LAWH_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block rounded-lg bg-pastel-azure px-8 py-3 text-sm font-semibold text-dark-blue transition-opacity hover:opacity-90"
        >
          Try Lawh for free
        </a>
      </div>
    </div>
  </div>
</section>
