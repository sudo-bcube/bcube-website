<section id="contact" class="px-6 py-24">
  <div class="mx-auto max-w-2xl">
    <h2 class="text-center text-3xl font-bold text-dark-blue sm:text-4xl">
      Questions? Ideas? We're listening.
    </h2>
    <p class="mt-4 text-center text-gray-600">
      Drop us a note, a thought, or an idea. We read everything and respond within 48 hours.
    </p>

    <form class="mt-12 space-y-6" onsubmit="event.preventDefault()">
      <div>
        <label for="name" class="block text-sm font-medium text-dark-blue">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="mt-1 w-full rounded-lg border border-gray-200 px-4 py-3 text-sm outline-none transition-colors focus:border-pastel-azure"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-dark-blue">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="mt-1 w-full rounded-lg border border-gray-200 px-4 py-3 text-sm outline-none transition-colors focus:border-pastel-azure"
        />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium text-dark-blue">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="mt-1 w-full resize-none rounded-lg border border-gray-200 px-4 py-3 text-sm outline-none transition-colors focus:border-pastel-azure"
        ></textarea>
      </div>
      <button
        type="submit"
        class="w-full rounded-lg bg-dark-blue px-8 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90"
      >
        Send Message
      </button>
    </form>
  </div>
</section>
