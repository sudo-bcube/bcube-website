---
const cards = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>`,
    title: "One challenge focus",
    text: "Each app tackles one challenge, not fifty half-baked features.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-8"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" /></svg>`,
    title: "Clean interfaces",
    text: "Clean, intuitive interfaces guide every tap, swipe, or click.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-8"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" /></svg>`,
    title: "Smooth task flow",
    text: "Tasks flow smoothly, letting you stay focused and in control.",
  },
];
---

<section id="how" class="px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <h2 class="text-center text-3xl font-bold text-dark-blue sm:text-4xl">
      Built for relief, crafted for control
    </h2>

    <div class="mt-16 grid gap-8 sm:grid-cols-3">
      {cards.map((card) => (
        <div class="rounded-2xl border border-gray-100 bg-white p-8 text-center shadow-sm transition-shadow hover:shadow-md">
          <div class="mx-auto flex size-14 items-center justify-center rounded-xl bg-pastel-azure/20 text-dark-blue">
            <Fragment set:html={card.icon} />
          </div>
          <h3 class="mt-5 text-lg font-semibold text-dark-blue">{card.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-gray-600">{card.text}</p>
        </div>
      ))}
    </div>

    <p class="mt-16 text-center text-lg italic text-gray-600">
      All culminating in that quiet moment of satisfaction. "Finally," you say. "Tools that actually work."
    </p>
  </div>
</section>
